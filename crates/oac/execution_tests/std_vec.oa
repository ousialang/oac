specialize IntVec = Vec[I32]

impl Copy for IntVec {
	fun copy(v: IntVec) -> IntVec {
		return v
	}
}

impl Copy for IntVec__SetResult {
	fun copy(v: IntVec__SetResult) -> IntVec__SetResult {
		return v
	}
}

impl Copy for IntVec__PopValue {
	fun copy(v: IntVec__PopValue) -> IntVec__PopValue {
		return v
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun print_lookup(v: IntVec__Lookup) -> I32 {
	match v {
		IntVec__Lookup.Missing => {
			print(99)
			return 0
		}
		IntVec__Lookup.Found(value) => {
			print(value)
			return 0
		}
	}
}

fun print_pop(v: IntVec__PopResult) -> I32 {
	match v {
		IntVec__PopResult.Empty => {
			print(99)
			return 0
		}
		IntVec__PopResult.Value(payload) => {
			print(payload.value)
			print(payload.vec.len())
			return 0
		}
	}
}

fun main() -> I32 {
	vec = IntVec.new()
	print(vec.len())
	print(vec.capacity())

	vec = vec.reserve(3)
	print(vec.capacity())

	vec = vec.push(10)
	vec = vec.push(20)
	vec = vec.push(30)
	print(vec.len())
	print(vec.capacity())
	print_lookup(vec.get(0))
	print_lookup(vec.get(1))
	print_lookup(vec.get(2))
	print_lookup(vec.get(9))

	updated = vec.set(1, 99)
	vec = updated.vec
	print_bool(updated.updated)
	print_lookup(vec.get(1))

	miss_update = vec.set(9, 50)
	print_bool(miss_update.updated)

	print_pop(vec.pop())
	match vec.pop() {
		IntVec__PopResult.Empty => {
			vec = vec
		}
		IntVec__PopResult.Value(payload) => {
			vec = payload.vec
		}
	}
	print(vec.len())

	vec = vec.clear()
	print(vec.len())
	print(vec.capacity())
	return 0
}
