fun main() -> I32 {
	ptr = Clib.calloc(i32_to_i64(1), i32_to_i64(8))

	u8_ref = U8Ref.from_ptr(ptr)
	i32_ref = I32Ref.from_ptr(ptr)
	i64_ref = I64Ref.from_ptr(ptr)
	ptr_ref = PtrIntRef.from_ptr(ptr)
	bool_ref = BoolRef.from_ptr(ptr)

	u8_val = u8_ref.read()
	i32_val = i32_ref.read()
	i64_val = i64_ref.read()
	ptr_val = ptr_ref.read()
	bool_val = bool_ref.read()

	if u8_val == u8_val {
		print(10)
	} else {
		print(11)
	}

	if i32_val == 0 {
		print(20)
	} else {
		print(21)
	}

	if i64_val == i32_to_i64(0) {
		print(30)
	} else {
		print(31)
	}

	if ptr_val == i32_to_i64(0) {
		print(40)
	} else {
		print(41)
	}

	if !bool_val {
		print(50)
	} else {
		print(51)
	}

	Clib.free(ptr)
	return 0
}
