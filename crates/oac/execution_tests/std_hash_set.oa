specialize IntSet = HashSet[I32]

impl Copy for IntSet {
	fun copy(v: IntSet) -> IntSet {
		return v
	}
}

impl Copy for IntSet__InsertResult {
	fun copy(v: IntSet__InsertResult) -> IntSet__InsertResult {
		return v
	}
}

impl Copy for IntSet__RemoveResult {
	fun copy(v: IntSet__RemoveResult) -> IntSet__RemoveResult {
		return v
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun main() -> I32 {
	set = IntSet.new()
	print(set.len())
	print(set.capacity())

	r1 = set.insert(1)
	set = r1.set
	print_bool(r1.inserted_new)
	r2 = set.insert(2)
	set = r2.set
	print_bool(r2.inserted_new)
	r3 = set.insert(1)
	set = r3.set
	print_bool(r3.inserted_new)
	print(set.len())
	print_bool(set.contains(1))
	print_bool(set.contains(9))

	removed = set.remove(2)
	set = removed.set
	print_bool(removed.removed)
	print(set.len())

	left = IntSet.new()
	left_i1 = left.insert(1)
	left = left_i1.set
	left_i2 = left.insert(3)
	left = left_i2.set
	right = IntSet.new()
	right_i1 = right.insert(3)
	right = right_i1.set
	right_i2 = right.insert(4)
	right = right_i2.set
	u = left.union(right)
	print(u.len())
	print_bool(u.contains(4))
	print_bool(u.contains(1))
	i = left.intersection(right)
	print(i.len())
	print_bool(i.contains(3))
	d = left.difference(right)
	print(d.len())
	print_bool(d.contains(1))
	print_bool(d.contains(3))

	set = set.clear()
	print(set.len())
	print(set.capacity())
	return 0
}
