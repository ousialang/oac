impl Copy for String {
	fun copy(v: String) -> String {
		return v
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun main() -> I32 {
	s = "alpha-beta"

	print_bool(s.equals("alpha-beta"))
	print_bool(s.equals("alpha"))
	print_bool(s.starts_with("alpha"))
	print_bool(s.starts_with("beta"))
	print_bool(s.ends_with("beta"))
	print_bool(s.ends_with("alpha"))

	print(s.char_at_or(0, 63))
	print(s.char_at_or(100, 63))

	clip_start = s.slice_clamped(0 - 2, 5)
	print(string_len(clip_start))
	print(char_at(clip_start, 0))

	clip_end = s.slice_clamped(6, 50)
	print(string_len(clip_end))
	print(char_at(clip_end, 0))
	print(char_at(clip_end, 3))

	empty = s.slice_clamped(100, 2)
	print(string_len(empty))
	print_bool(empty.is_empty())

	return 0
}
