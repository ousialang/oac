struct Envelope {
	raw: I32,
	abs: I32,
	checksum: I32,
}

invariant stable_envelope "envelope stays normalized and stable" for (v: Envelope) {
	return v.abs >= 0 && v.abs >= v.raw && v.checksum == 0
}

fun normalize(x: I32) -> I32 {
	assert(x >= (0 - 2147483647))
	if x < 0 {
		return 0 - x
	} else {
		return x
	}
}

fun build_seed(base: I32) -> I32 {
	if base < 16 {
		return (base + 4) + 3
	} else {
		return 23
	}
}

fun build_raw(seed: I32, offset: I32) -> I32 {
	assert(seed >= 0)
	assert(offset >= 0)
	if seed < offset {
		delta = offset - seed
		assert(delta >= 0)
		return 0 - delta
	} else {
		return seed - offset
	}
}

fun make_envelope(seed: I32, offset: I32) -> Envelope {
	raw = build_raw(seed, offset)
	abs = normalize(raw)
	checksum = 1
	return Envelope struct { raw: raw, abs: abs, checksum: checksum, }
}

fun main() -> I32 {
	base = 12
	offset = 40
	seed = build_seed(base)
	env = make_envelope(seed, offset)
	print(env.abs)
	return 0
}
