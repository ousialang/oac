specialize IntList = LinkedList[I32]

impl Copy for IntList {
	fun copy(v: IntList) -> IntList {
		return v
	}
}

fun main() -> I32 {
	xs = IntList.empty()
	xs = IntList.push_front(3, xs)
	xs = IntList.push_front(2, xs)
	xs = IntList.push_front(1, xs)

	print(xs.length())
	print(xs.head_or(99))

	ys = xs.tail_or(IntList.empty())
	print(ys.head_or(99))

	zs = IntList.empty().tail_or(ys)
	print(zs.length())

	if IntList.empty().is_empty() {
		print(1)
	} else {
		print(0)
	}
	if xs.is_empty() {
		print(1)
	} else {
		print(0)
	}

	return 0
}
