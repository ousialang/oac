specialize IntTable = HashTable[I32, I32]

impl Copy for IntTable {
	fun copy(v: IntTable) -> IntTable {
		return v
	}
}

impl Copy for IntTable__SetResult {
	fun copy(v: IntTable__SetResult) -> IntTable__SetResult {
		return v
	}
}

impl Copy for IntTable__RemoveResult {
	fun copy(v: IntTable__RemoveResult) -> IntTable__RemoveResult {
		return v
	}
}

fun print_lookup(v: IntTable__Lookup) -> I32 {
	match v {
		IntTable__Lookup.Missing => {
			print(99)
			return 0
		}
		IntTable__Lookup.Found(x) => {
			print(x)
			return 0
		}
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun main() -> I32 {
	table = IntTable.new()
	print(table.len())
	print(table.capacity())

	r1 = table.set(1, 10)
	table = r1.table
	print_bool(r1.inserted_new)
	r2 = table.set(9, 90)
	table = r2.table
	print_bool(r2.inserted_new)
	r3 = table.set(17, 170)
	table = r3.table
	print_bool(r3.inserted_new)
	print(table.len())

	print_lookup(table.get(1))
	print_lookup(table.get(9))
	print_lookup(table.get(17))
	print_lookup(table.get(42))

	r4 = table.set(1, 11)
	table = r4.table
	print_bool(r4.inserted_new)
	print(table.len())
	print_lookup(table.get(1))

	removed1 = table.remove(9)
	table = removed1.table
	print_lookup(removed1.removed)
	print(table.len())
	print_lookup(table.get(9))

	removed2 = table.remove(9)
	table = removed2.table
	print_lookup(removed2.removed)
	print(table.len())

	print(table.capacity())
	r = table.set(100, 0)
	table = r.table
	r = table.set(101, 1)
	table = r.table
	r = table.set(102, 2)
	table = r.table
	r = table.set(103, 3)
	table = r.table
	r = table.set(104, 4)
	table = r.table
	r = table.set(105, 5)
	table = r.table
	r = table.set(106, 6)
	table = r.table
	r = table.set(107, 7)
	table = r.table
	r = table.set(108, 8)
	table = r.table
	r = table.set(109, 9)
	table = r.table
	r = table.set(110, 10)
	table = r.table
	r = table.set(111, 11)
	table = r.table
	r = table.set(112, 12)
	table = r.table
	r = table.set(113, 13)
	table = r.table
	r = table.set(114, 14)
	table = r.table
	r = table.set(115, 15)
	table = r.table
	r = table.set(116, 16)
	table = r.table
	r = table.set(117, 17)
	table = r.table
	r = table.set(118, 18)
	table = r.table
	r = table.set(119, 19)
	table = r.table
	print(table.len())
	print(table.capacity())
	print_lookup(table.get(1))
	print_lookup(table.get(17))
	print_lookup(table.get(119))
	print_bool(table.contains_key(42))
	print_bool(table.contains_key(119))

	table = table.clear()
	print(table.len())
	print(table.capacity())

	return 0
}
