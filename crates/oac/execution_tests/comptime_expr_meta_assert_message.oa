struct Counter {
	value: I32,
}

comptime fun meta_probe(T: Type) -> DeclSet {
	meta_from_param = Meta.expr_opt(T)
	meta_from_expr = Meta.expr_opt(Type.resolve("I32"))
	assert(!meta_from_param.is_some())
	assert(meta_from_expr.is_some())
	return DeclSet.new()
}

comptime apply meta_probe(Counter)

fun main() -> I32 {
	print(5)
	return 0
}
