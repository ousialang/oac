impl Copy for U8Mut {
	fun copy(v: U8Mut) -> U8Mut {
		return v
	}
}

impl Copy for I32Mut {
	fun copy(v: I32Mut) -> I32Mut {
		return v
	}
}

impl Copy for I64Mut {
	fun copy(v: I64Mut) -> I64Mut {
		return v
	}
}

impl Copy for BoolMut {
	fun copy(v: BoolMut) -> BoolMut {
		return v
	}
}

impl Copy for PtrIntMut {
	fun copy(v: PtrIntMut) -> PtrIntMut {
		return v
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun main() -> I32 {
	ptr = Clib.calloc(i32_to_i64(1), i32_to_i64(16))

	u8_mut = U8Mut.from_ptr(ptr)
	u8_zero = u8_mut.read()
	u8_mut.write(u8_zero)
	print_bool(u8_mut.read() == u8_zero)

	u8_next = u8_mut.add_bytes(i32_to_i64(1))
	u8_next_zero = u8_next.read()
	u8_next.write(u8_next_zero)
	print_bool(u8_next.read() == u8_next_zero)

	i32_mut = I32Mut.from_ptr(ptr)
	i32_mut.write(1234)
	print(i32_mut.read())

	i64_mut = I64Mut.from_ptr(ptr + i32_to_i64(8))
	i64_mut.write(i32_to_i64(9001))
	print_bool(i64_mut.read() == i32_to_i64(9001))

	bool_mut = BoolMut.from_ptr(ptr)
	bool_mut.write(true)
	print_bool(bool_mut.read())

	ptr_mut = PtrIntMut.from_ptr(ptr)
	ptr_mut.write(ptr)
	print_bool(ptr_mut.read() == ptr)

	Clib.free(ptr)
	return 0
}
