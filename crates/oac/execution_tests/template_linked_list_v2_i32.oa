specialize IntList = LinkedList[I32]

impl Copy for IntList {
	fun copy(v: IntList) -> IntList {
		return v
	}
}

impl Copy for IntList__PopFrontValue {
	fun copy(v: IntList__PopFrontValue) -> IntList__PopFrontValue {
		return v
	}
}

fun print_front(v: IntList__FrontOption) -> I32 {
	match v {
		IntList__FrontOption.None => {
			print(99)
			return 0
		}
		IntList__FrontOption.Some(x) => {
			print(x)
			return 0
		}
	}
}

fun print_tail(v: IntList__TailOption) -> I32 {
	match v {
		IntList__TailOption.None => {
			print(99)
			return 0
		}
		IntList__TailOption.Some(rest) => {
			print(rest.len())
			return 0
		}
	}
}

fun print_pop(v: IntList__PopFrontOption) -> I32 {
	match v {
		IntList__PopFrontOption.None => {
			print(99)
			return 0
		}
		IntList__PopFrontOption.Some(r) => {
			print(r.value)
			print(r.rest.len())
			return 0
		}
	}
}

fun main() -> I32 {
	xs = IntList.empty()
	print(xs.len())
	print(xs.length())

	xs = IntList.singleton(2)
	xs = IntList.cons(1, xs)
	xs = IntList.push_front(0, xs)
	print(xs.len())
	print(xs.head_or(77))
	print_front(xs.front())
	print_tail(xs.tail())

	print(xs.at_or(1, 77))
	print_front(xs.at(2))
	print_front(xs.at(5))

	tail = xs.tail_or(IntList.empty())
	print(tail.len())
	print_pop(xs.pop_front())

	ys = IntList.push_front(4, IntList.push_front(3, IntList.empty()))
	app = xs.append(ys)
	print(app.len())
	print(app.at_or(4, 77))

	rev = app.reverse()
	print(rev.at_or(0, 77))

	taken = app.take(3)
	print(taken.len())
	print(taken.at_or(2, 77))

	dropped = app.drop(2)
	print(dropped.len())
	print(dropped.at_or(0, 77))

	print(app.take(0 - 1).len())
	print(app.drop(0 - 1).len())

	return 0
}
