specialize OptionI32 = Option[I32]
specialize ResultI32Bool = Result[I32, Bool]

impl Copy for OptionI32 {
	fun copy(v: OptionI32) -> OptionI32 {
		return v
	}
}

impl Copy for ResultI32Bool {
	fun copy(v: ResultI32Bool) -> ResultI32Bool {
		return v
	}
}

fun print_bool(v: Bool) -> I32 {
	if v {
		print(1)
	} else {
		print(0)
	}
	return 0
}

fun main() -> I32 {
	none = OptionI32.none()
	some = OptionI32.some(7)
	print_bool(none.is_none())
	print_bool(none.is_some())
	print_bool(some.is_some())
	print(none.unwrap_or(11))
	print(some.unwrap_or(11))

	ok = ResultI32Bool.ok(9)
	err = ResultI32Bool.err(true)
	print_bool(ok.is_ok())
	print_bool(ok.is_err())
	print_bool(err.is_err())
	print(ok.unwrap_or(1))
	print(err.unwrap_or(1))
	print_bool(ok.unwrap_err_or(false))
	print_bool(err.unwrap_err_or(false))

	return 0
}
