specialize OptionI32 = Option[I32]

impl Copy for OptionI32 {
	fun copy(v: OptionI32) -> OptionI32 {
		return v
	}
}

fun main() -> I32 {
	a = OptionI32.Some(7)
	b = OptionI32.None

	if OptionI32.is_some(a) {
		print(OptionI32.unwrap_or(a, 0))
	}

	if OptionI32.is_some(b) {
		print(1)
	} else {
		print(OptionI32.unwrap_or(b, 9))
	}

	return 0
}
