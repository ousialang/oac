specialize OptionI32 = Option[I32]

impl Copy for OptionI32 {
	fun copy(v: OptionI32) -> OptionI32 {
		return v
	}
}

fun main() -> I32 {
	a = OptionI32.Some(7)
	b = OptionI32.None

	if a.is_some() {
		print(a.unwrap_or(0))
	}

	if b.is_some() {
		print(1)
	} else {
		print(b.unwrap_or(9))
	}

	return 0
}
